# Environment Configuration — Food Donation & Redistribution System
# Copy to .env and fill in real values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Replace <username>, <password>, <cluster>, <dbname> with your actual Atlas values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=FoodDonation

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_in_prod
JWT_REFRESH_EXPIRES_IN=30d

# ── Frontend / CORS ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173
# Production (Netlify etc.): set to your real site URL(s). Socket.io CORS must allow the Netlify origin.
# CLIENT_URL=https://your-app.netlify.app
# SOCKET_CORS_ORIGIN=https://your-app.netlify.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Email (Nodemailer / Gmail SMTP) ───────────────────────────────────────────
# For Gmail: enable 2FA and use App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="Food Donation System <noreply@fooddonation.com>"

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ── Database seed (backend/seed.js only — never use production passwords here) ─
# All demo users get this password when you run: node seed.js
SEED_DEFAULT_PASSWORD=change_this_local_only_min_8_chars

# Optional: seed_admin.js (root) — register one admin via API
# SEED_ADMIN_EMAIL=admin@system.com
# SEED_ADMIN_PASSWORD=change_this_local_only_min_8_chars
# API_URL=http://localhost:5000/api
