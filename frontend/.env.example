# Copy to .env — do not commit .env
# Vite only exposes variables prefixed with VITE_

# Backend API (no secrets in the URL unless you use basic auth — prefer separate auth headers)
VITE_API_URL=http://localhost:5000/api

# Optional: Google Maps JavaScript API key (restrict key by HTTP referrer in Google Cloud)
# VITE_GOOGLE_MAPS_API_KEY=
