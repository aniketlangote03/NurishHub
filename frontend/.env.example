# Copy to .env — do not commit .env
# Vite only exposes variables prefixed with VITE_

# Backend REST API (must end with /api to match backend routes)
VITE_API_URL=http://localhost:5000/api

# Socket.io server (same host as API, no /api path)
VITE_SOCKET_URL=http://localhost:5000

# Netlify / production: set BOTH in Site settings → Environment variables, then redeploy.
# Example (replace with your real API host):
#   VITE_API_URL=https://api.yourdomain.com/api
#   VITE_SOCKET_URL=https://api.yourdomain.com

# Optional: Google Maps JavaScript API key (restrict key by HTTP referrer in Google Cloud)
# VITE_GOOGLE_MAPS_API_KEY=
